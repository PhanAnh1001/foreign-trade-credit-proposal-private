# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3
DATA_DIR=data                  # override data root (absolute or relative to project)

# ── S3 (only used when STORAGE_BACKEND=s3) ────────────────────────────────────
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_UPLOADS_PREFIX=uploads/
S3_OUTPUTS_PREFIX=outputs/
S3_CACHE_PREFIX=cache/ocr/

# ── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
TAVILY_API_KEY=                # leave empty to fall back to LLM knowledge
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=credit-proposal-agent
# ── OCR flags ────────────────────────────────────────────────────────────────
OCR_ONLINE_DISABLED=false      # set true to skip Vision LLM OCR (Strategy 3)
